# ===================================
# 개인 설정 (각자 다르게!)
# ===================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# ===================================
# Database 설정 (스키마 분리 방식)
# ===================================
POSTGRES_DB=logistics_db

# ===================================
# 참고:
# - 단일 PostgreSQL 인스턴스 사용
# - Host: localhost
# - Port: 5432 (공통)
# - Database: logistics_db (공통)
# - 각 서비스는 Schema로 구분
#   - company_schema
#   - product_schema
#   - order_schema
#   - hub_schema
#   - user_schema
#   - auth_schema
#   - delivery_schema
#   - ai_schema
#   - alarm_schema
# ===================================